# ===========================================
# Мебельный Завод — Переменные окружения
# ===========================================
# Скопируй этот файл как .env и заполни значения:
#   cp .env.example .env
#   nano .env

# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=ВСТАВЬ_СЮДА_ТОКЕН_ОТ_BOTFATHER

# URL Mini App (HTTPS обязателен для Telegram WebApp!)
# Примеры:
#   https://mebel.your-domain.ru  — свой домен + Caddy
#   https://abc123.ngrok-free.app — через ngrok (временно)
WEBAPP_URL=
